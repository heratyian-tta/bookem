<div id="<%= dom_id booking %>">
<% if current_user.id == booking.guest_id || booking.location.host_id == current_user.id %>
  
  <p>
    <strong>Started at:</strong>
    <%= booking.started_at %>
  </p>

  <p>
    <strong>Ended at:</strong>
    <%= booking.ended_at %>
  </p>

  <p>
    <strong>Guest:</strong>
    <%= booking.guest.first_name %>
  </p>

  <p>
    <strong>Location:</strong>
    <%= booking.location.name %>
  </p>

</div>
<% end %>
